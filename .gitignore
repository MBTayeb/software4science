# 1. Ignore everything by default
*

# 2. Allow all directories so Git can scan them for the allowed files
!*/

# 3. Explicitly allow your specific files (wherever they are)
!loader.html
!page.html
!title.txt

# 4. Explicitly allow the entire 'assets' folder and its contents
!assets/
!assets/**

# 5. Hard block specific files and folders (Overrides the allows above)
kubernetes/
save.html
ToDo.md
codebook.toml
*.py
my_loaders.txt

# 6. Ignore private folders starting with a dot or an underscore
**/.*
**/_*

# 7. Ensure Git configuration files are tracked
!.gitignore
!.gitattributes
